{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "omSchemaVersion": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "performanceArea": {
          "type": "object",
          "properties": {
            "yOrigin": {
              "type": "string",
              "const": "front"
            },
            "inchesPerStep": {
              "type": "number"
            },
            "xCheckpoints": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "terseName": {
                    "type": "string"
                  },
                  "useAsReference": {
                    "type": "boolean"
                  },
                  "fieldLabel": {
                    "type": "string"
                  },
                  "visible": {
                    "type": "boolean"
                  },
                  "stepsFromCenter": {
                    "type": "number"
                  }
                },
                "required": [
                  "name",
                  "terseName",
                  "useAsReference",
                  "visible",
                  "stepsFromCenter"
                ],
                "additionalProperties": false
              }
            },
            "yCheckpoints": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "terseName": {
                    "type": "string"
                  },
                  "useAsReference": {
                    "type": "boolean"
                  },
                  "fieldLabel": {
                    "type": "string"
                  },
                  "visible": {
                    "type": "boolean"
                  },
                  "stepsFromYOrigin": {
                    "type": "number"
                  }
                },
                "required": [
                  "name",
                  "terseName",
                  "useAsReference",
                  "visible",
                  "stepsFromYOrigin"
                ],
                "additionalProperties": false
              }
            },
            "widthInches": {
              "type": "number"
            },
            "heightInches": {
              "type": "number"
            },
            "useHashes": {
              "type": "boolean"
            }
          },
          "required": [
            "yOrigin",
            "inchesPerStep",
            "xCheckpoints",
            "yCheckpoints",
            "widthInches",
            "heightInches",
            "useHashes"
          ],
          "additionalProperties": false
        },
        "createdAtUtc": {
          "type": "string"
        },
        "audioOffsetSeconds": {
          "type": "number"
        },
        "info": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string"
            },
            "author": {
              "type": "string"
            },
            "school": {
              "type": "string"
            },
            "year": {
              "type": "string"
            }
          },
          "additionalProperties": {}
        }
      },
      "required": [
        "performanceArea",
        "createdAtUtc"
      ],
      "additionalProperties": false
    },
    "performers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "label": {
            "type": "string"
          },
          "section": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "label",
          "section"
        ],
        "additionalProperties": false
      }
    },
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "duration": {
            "type": "number"
          },
          "startBeatIndex": {
            "type": "number"
          },
          "isSubset": {
            "type": "boolean"
          },
          "name": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "duration",
          "startBeatIndex",
          "name"
        ],
        "additionalProperties": false
      }
    },
    "tempoSections": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "tempo": {
            "type": "number"
          },
          "numberOfBeats": {
            "type": "number"
          }
        },
        "required": [
          "tempo",
          "numberOfBeats"
        ],
        "additionalProperties": false
      }
    },
    "coordinates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "marcherId": {
            "type": "string"
          },
          "pageId": {
            "type": "string"
          },
          "xSteps": {
            "type": "number"
          },
          "ySteps": {
            "type": "number"
          },
          "rotation_degrees": {
            "type": "number"
          }
        },
        "required": [
          "marcherId",
          "pageId",
          "xSteps",
          "ySteps"
        ],
        "additionalProperties": false
      }
    },
    "measures": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "startBeatIndex": {
            "type": "number"
          },
          "name": {
            "type": "string"
          },
          "rehearsalMark": {
            "type": "string"
          }
        },
        "required": [
          "startBeatIndex",
          "name"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "omSchemaVersion",
    "metadata",
    "performers",
    "pages",
    "tempoSections",
    "coordinates"
  ],
  "additionalProperties": false
}