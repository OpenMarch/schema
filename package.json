{
	"name": "@openmarch/schema",
	"version": "0.1.1",
	"description": "OpenMarch Data Format for storing and processing marching band, indoor, and drum corps drill shows",
	"license": "Apache-2.0",
	"homepage": "https://openmarch.com",
	"author": "OpenMarch LLC <contact@openmarch.com>",
	"repository": {
		"type": "git",
		"url": "https://github.com/OpenMarch/schema.git"
	},
	"publishConfig": {
		"@openmarch:registry": "https://npm.pkg.github.com"
	},
	"module": "src/index.ts",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"import": "./src/index.ts",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "bun build ./src/index.ts --outdir ./dist --target node",
		"build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
		"generate-schema": "bun run ./scripts/generate-json-schema.ts",
		"test": "bun test"
	},
	"files": [
		"dist",
		"src",
		"schema.json"
	],
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"@types/bun": "latest",
		"cspell": "^9.4.0",
		"lefthook": "^2.0.13"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"zod": "^4.3.5"
	}
}
