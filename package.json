{
	"name": "@openmarch/schema",
	"version": "0.3.7",
	"description": "OpenMarch Data Format for storing and processing marching band, indoor, and drum corps drill shows",
	"license": "Apache-2.0",
	"homepage": "https://openmarch.com",
	"author": "OpenMarch LLC <contact@openmarch.com>",
	"repository": {
		"type": "git",
		"url": "https://github.com/OpenMarch/schema.git"
	},
	"module": "dist/index.js",
	"main": "dist/index.cjs",
	"types": "dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.cjs"
			},
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsc && bun run scripts/build.ts",
		"generate-schema": "bun run ./scripts/generate-json-schema.ts",
		"test": "bun test"
	},
	"files": [
		"dist",
		"schema.json",
		"schema-tempo.json"
	],
	"devDependencies": {
		"@biomejs/biome": "2.3.11",
		"@types/bun": "latest",
		"cspell": "^9.4.0",
		"lefthook": "^2.0.13"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"zod": "^4.3.5"
	}
}
